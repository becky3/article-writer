{
  "config": {
    "MD013": {
      "line_length": 200,
      "code_blocks": false,
      "tables": false
    },
    "MD024": false,
    "MD029": false,
    "MD036": false,
    "MD040": false,
    "MD041": false,
    "MD060": false
  },
  "ignores": [
    // 生成された日記記事は、フロントマター + H1 重複（MD025）・HTML 埋め込み（MD033）・
    // 日本語段落の line-length 超過（MD013）が頻発するため lint 対象外とする。
    // 日記記事は人手レビューを経て公開する前提で、機械的 lint の便益が低い。
    "articles/hatena/**/*.md",
    // .gitignore 対象の一時作業領域。triage 確認表ファイル等が lint 対象に混入することを避ける。
    "aidlc-docs/**",
    "aidlc-archive/**"
  ],
  "globs": [
    "articles/**/*.md",
    "docs/**/*.md",
    "*.md",
    ".claude/**/*.md",
    ".github/prompts/*.md"
  ]
}
